<Window x:Class="TabHistorian.Viewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TabHistorian.Viewer.ViewModels"
        Title="Tab Historian" Width="1400" Height="700"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI, Segoe UI Emoji"
        Icon="app.ico">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Search bar -->
        <Grid Grid.Row="0">
            <TextBox x:Name="SearchBox"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Padding="8,6" FontSize="14"
                     KeyDown="SearchBox_KeyDown"/>
            <TextBlock Text="Search tabs, URLs, history..."
                       Foreground="Gray" FontSize="14"
                       Padding="10,7" VerticalAlignment="Center"
                       IsHitTestVisible="False">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <!-- Filters -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,6,0,6">
            <TextBlock Text="Snapshot:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox x:Name="SnapshotCombo" Width="350"
                      ItemsSource="{Binding Snapshots}"
                      SelectedItem="{Binding SelectedSnapshot}"
                      Padding="4">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock>
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0}  ({1} windows, {2} tabs)">
                                    <Binding Path="Timestamp"/>
                                    <Binding Path="WindowCount"/>
                                    <Binding Path="TabCount"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Text="Profile:" VerticalAlignment="Center" Margin="12,0,6,0"/>
            <ComboBox x:Name="ProfileCombo" Width="200"
                      ItemsSource="{Binding Profiles}"
                      SelectedItem="{Binding SelectedProfile}"
                      DisplayMemberPath="ProfileDisplayName"
                      Padding="4"/>
            <Button Content="Clear" Margin="6,0,0,0" Padding="8,4" Click="ClearFilter_Click"/>
        </StackPanel>

        <!-- Main content: tree + detail panel -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="280"/>
            </Grid.ColumnDefinitions>

            <!-- Results tree -->
            <TreeView Grid.Column="0" x:Name="ResultsTree"
                      ItemsSource="{Binding Results}"
                      BorderThickness="1" Padding="4"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      SelectedItemChanged="ResultsTree_SelectedItemChanged">
                <TreeView.Resources>
                    <!-- Snapshot level -->
                    <HierarchicalDataTemplate DataType="{x:Type vm:SnapshotNode}" ItemsSource="{Binding Profiles}">
                        <TextBlock Text="{Binding Display}" FontWeight="Bold" FontSize="13" Margin="0,2"/>
                    </HierarchicalDataTemplate>

                    <!-- Profile level -->
                    <HierarchicalDataTemplate DataType="{x:Type vm:ProfileNode}" ItemsSource="{Binding Windows}">
                        <TextBlock Text="{Binding Display}" FontWeight="SemiBold" FontSize="12.5" Margin="0,1" Foreground="#444"/>
                    </HierarchicalDataTemplate>

                    <!-- Window level -->
                    <HierarchicalDataTemplate DataType="{x:Type vm:WindowNode}" ItemsSource="{Binding Tabs}">
                        <TextBlock Text="{Binding Display}" FontSize="12.5" Margin="0,1"/>
                    </HierarchicalDataTemplate>

                    <!-- Tab level -->
                    <HierarchicalDataTemplate DataType="{x:Type vm:TabNode}" ItemsSource="{Binding NavEntries}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{Binding Favicon}" Width="16" Height="16" Margin="0,0,4,0"
                                   VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock Text="{Binding Display}" FontSize="12" Foreground="#333" Margin="0,1"
                                       TextTrimming="CharacterEllipsis" MaxWidth="700" VerticalAlignment="Center"/>
                        </StackPanel>
                    </HierarchicalDataTemplate>

                    <!-- Nav entry (leaf) -->
                    <DataTemplate DataType="{x:Type vm:NavEntryNode}">
                        <TextBlock Text="{Binding Display}" FontSize="11" Foreground="#666"
                                   TextTrimming="CharacterEllipsis" MaxWidth="650"/>
                    </DataTemplate>
                </TreeView.Resources>

                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay, FallbackValue=False}"/>
                    </Style>
                </TreeView.ItemContainerStyle>
            </TreeView>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="Transparent" Cursor="SizeWE"/>

            <!-- Detail panel -->
            <Border Grid.Column="2" BorderThickness="1" BorderBrush="#DDD" Padding="10" Margin="4,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="DetailPanel">
                        <TextBlock x:Name="DetailPlaceholder"
                                   Text="Select a window, tab, or history entry to view details."
                                   Foreground="#999" FontStyle="Italic"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="3" BorderThickness="0,1,0,0" BorderBrush="#DDD" Margin="0,4,0,0" Padding="0,4,0,0">
            <TextBlock Text="{Binding StatusText}" Foreground="#666" FontSize="11.5"/>
        </Border>
    </Grid>
</Window>
